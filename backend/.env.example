APP_NAME="LeadHive Automation"
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=sqlite:///./database/leadhive.db
FRONTEND_ORIGIN=http://localhost:5173
PUBLIC_SOURCE_USER_AGENT="LeadHiveAutomation/1.0 contact@example.com"
SCRAPER_REQUEST_TIMEOUT=20
WEBSITE_ANALYSIS_TIMEOUT=12
ENABLE_PLAYWRIGHT_ANALYSIS=false
EMAIL_SENDING_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME="LeadHive Automation"
EMAIL_RATE_LIMIT_PER_HOUR=20
UNSUBSCRIBE_TEXT="If this is not relevant, reply with 'unsubscribe' and we will not contact you again."
LOG_LEVEL=INFO

